# Copy this file to `.streamlit/secrets.toml` (which is git-ignored) for LOCAL runs,
# or paste the same keys into the "Secrets" box of your Streamlit Community Cloud app.
# NONE of these are required for the POC — the app runs fully in demo mode without them.

# Leave DEMO_MODE on (default) to hide the live-price fetch and Claude phrasing for a
# clean client demo. Set it to "0" to enable those features (then the keys below matter).
DEMO_MODE = "1"

# Only needed once DEMO_MODE = "0":
# ANTHROPIC_API_KEY = "sk-ant-..."        # v10: powers the Proposal page's "Generate with
#                                         # Claude" button + grounded phrasing in Ask the book
# FRED_API_KEY = "your-fred-key"          # macro rates in datafeed.py (live market data only)
